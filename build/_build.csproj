<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>ReactiveUI.Web</RootNamespace>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <ItemGroup>
      <None Include="..\docs\**\*.*" LinkBase="docs" Exclude="..\docs\api\lib\**\*.*;..\docs\api\refs\**\*.*;..\docs\api\cache\**\*.*" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="System.CommandLine" />
        <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="NuStreamDocs" />
        <PackageReference Include="NuStreamDocs.Autorefs" />
        <PackageReference Include="NuStreamDocs.Blog" />
        <PackageReference Include="NuStreamDocs.Blog.Common" />
        <PackageReference Include="NuStreamDocs.CSharpApiGenerator" />
        <PackageReference Include="NuStreamDocs.Emoji" />
        <PackageReference Include="NuStreamDocs.Highlight" />
        <PackageReference Include="NuStreamDocs.Icons.FontAwesome" />
        <PackageReference Include="NuStreamDocs.Icons.Material" />
        <PackageReference Include="NuStreamDocs.Icons.MaterialDesign" />
        <PackageReference Include="NuStreamDocs.Lightbox" />
        <PackageReference Include="NuStreamDocs.LinkValidator" />
        <PackageReference Include="NuStreamDocs.MagicLink" />
        <PackageReference Include="NuStreamDocs.MarkdownExtensions" />
        <PackageReference Include="NuStreamDocs.Nav" />
        <PackageReference Include="NuStreamDocs.Optimize" />
        <PackageReference Include="NuStreamDocs.Privacy" />
        <PackageReference Include="NuStreamDocs.Search" />
        <PackageReference Include="NuStreamDocs.Serve" />
        <PackageReference Include="NuStreamDocs.Sitemap" />
        <PackageReference Include="NuStreamDocs.SuperFences" />
        <PackageReference Include="NuStreamDocs.Theme.Material3" />
        <PackageReference Include="NuStreamDocs.Toc" />
    </ItemGroup>


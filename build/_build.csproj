<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace></RootNamespace>
        <NukeRootDirectory>..</NukeRootDirectory>
        <NukeScriptDirectory>..</NukeScriptDirectory>
        <NukeTelemetryVersion>1</NukeTelemetryVersion>
        <IsPackable>false</IsPackable>
        <!-- CS0649: Nuke parameter fields (e.g. FailOnBrokenSourceLinks) are
             assigned by reflection from the matching command-line argument,
             so the compiler can't see the assignment. -->
        <NoWarn>$(NoWarn);CS0649</NoWarn>
    </PropertyGroup>

    <ItemGroup>
      <None Include="..\docs\**\*.*" LinkBase="docs" Exclude="..\docs\api\lib\**\*.*;..\docs\api\refs\**\*.*;..\docs\api\cache\**\*.*" />
      <None Include="..\mkdocs.yml" />
      <None Include="..\requirements.txt" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Nuke.Common" />
        <PackageReference Include="Serilog.Extensions.Logging" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="SourceDocParser" />
        <PackageReference Include="SourceDocParser.NuGet" />
        <PackageReference Include="SourceDocParser.Zensical" />
    </ItemGroup>
</Project>
